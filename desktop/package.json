{
  "name": "wayas-wheel-desktop",
  "version": "1.0.0",
  "description": "Desktop version of Waya's Wheel of Regret with local AI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-portable": "electron-builder --win portable",
    "build-steam": "electron-builder --win --config.steam=true"
  },
  "build": {
    "appId": "com.waya.wheelofregret",
    "productName": "Waya's Wheel of Regret",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../client/build/**/*"
    ],
    "extraResources": [
      "../server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": true,
      "language": "1033"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "keywords": ["electron", "desktop", "wheel", "regret", "ai"],
  "author": "Waya",
  "license": "MIT"
}
